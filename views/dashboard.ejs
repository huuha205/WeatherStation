<!-- Sensor Cards -->
<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-8">
    <div class="sensor-card stagger-1">
        <div class="sensor-icon temp"><i class="fa-solid fa-temperature-half"></i></div>
        <div class="sensor-label">Nhiệt độ</div>
        <div class="sensor-value" id="card-temp">--<span class="unit">°C</span></div>
        <div class="sensor-status" id="status-temp">Đang chờ...</div>
        <canvas class="sensor-sparkline" id="spark-temp"></canvas>
    </div>

    <div class="sensor-card stagger-2">
        <div class="sensor-icon hum"><i class="fa-solid fa-droplet"></i></div>
        <div class="sensor-label">Độ ẩm</div>
        <div class="sensor-value" id="card-hum">--<span class="unit">%</span></div>
        <div class="sensor-status" id="status-hum">Đang chờ...</div>
        <canvas class="sensor-sparkline" id="spark-hum"></canvas>
    </div>

    <div class="sensor-card stagger-3">
        <div class="sensor-icon pres"><i class="fa-solid fa-gauge-high"></i></div>
        <div class="sensor-label">Áp suất</div>
        <div class="sensor-value" id="card-pres">--<span class="unit">hPa</span></div>
        <div class="sensor-status" id="status-pres">Đang chờ...</div>
        <canvas class="sensor-sparkline" id="spark-pres"></canvas>
    </div>

    <div class="sensor-card stagger-4">
        <div class="sensor-icon rain"><i class="fa-solid fa-cloud-rain"></i></div>
        <div class="sensor-label">Lượng mưa</div>
        <div class="sensor-value" id="card-rain">--<span class="unit">mm</span></div>
        <div class="sensor-status" id="status-rain">Đang chờ...</div>
        <canvas class="sensor-sparkline" id="spark-rain"></canvas>
    </div>

    <div class="sensor-card stagger-5">
        <div class="sensor-icon wind"><i class="fa-solid fa-wind"></i></div>
        <div class="sensor-label">Tốc độ gió</div>
        <div class="sensor-value" id="card-wind">--<span class="unit">km/h</span></div>
        <div class="sensor-status" id="status-wind">Đang chờ...</div>
        <canvas class="sensor-sparkline" id="spark-wind"></canvas>
    </div>

    <div class="sensor-card stagger-6">
        <div class="sensor-icon light"><i class="fa-solid fa-sun"></i></div>
        <div class="sensor-label">Ánh sáng</div>
        <div class="sensor-value" id="card-light">--<span class="unit">lux</span></div>
        <div class="sensor-status" id="status-light">Đang chờ...</div>
        <canvas class="sensor-sparkline" id="spark-light"></canvas>
    </div>
</div>

<!-- AI Insight -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
    
    <!-- AI Weather Insight (Full Width) -->
    <div class="lg:col-span-3 ai-section stagger-7">
        <div class="flex items-center justify-between mb-6">
            <h2 class="ai-section-title mb-0">
                <i class="fa-solid fa-robot"></i> Phân tích thời tiết AI
            </h2>
            <div class="flex items-center gap-3">
                <div class="flex items-center gap-2 text-xs text-white/40">
                    <span class="live-dot"></span> Trực tiếp
                </div>
                <button class="btn-glass" onclick="forceAI()" id="btn-force-ai">
                    <i class="fa-solid fa-arrow-rotate-right"></i> Làm mới
                </button>
            </div>
        </div>
        
        <div id="ai-realtime-box">
            <!-- Skeleton -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="space-y-4">
                    <div class="ai-block"><div class="skeleton h-5 w-2/3 mb-3"></div><div class="skeleton h-8 w-1/2"></div></div>
                    <div class="ai-block"><div class="skeleton h-5 w-1/2 mb-3"></div><div class="skeleton h-8 w-1/3"></div></div>
                </div>
                <div class="space-y-4">
                    <div class="ai-block"><div class="skeleton h-5 w-2/3 mb-3"></div><div class="skeleton h-16 w-full"></div></div>
                    <div class="skeleton h-12 w-full rounded-xl"></div>
                    <div class="skeleton h-12 w-full rounded-xl"></div>
                </div>
            </div>
        </div>
    </div>
    </div>
</div>

<!-- Chart -->
<div class="glass-card stagger-7">
    <div class="flex items-center justify-between mb-6">
        <h3 class="text-base font-bold flex items-center gap-2">
            <i class="fa-solid fa-chart-area text-secondary"></i> Biểu đồ thời tiết 24h
        </h3>
        <span class="text-xs text-white/30">Dữ liệu thời gian thực</span>
    </div>
    <div class="chart-container">
        <canvas id="weatherChart"></canvas>
    </div>
</div>
