<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Smart Weather Monitoring System - IoT Dashboard">
    <title><%= title %> — Smart Weather</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#3B82F6',
                        secondary: '#06B6D4',
                        accent: '#38BDF8',
                        danger: '#EF4444',
                        warning: '#F59E0B',
                        success: '#22C55E',
                    }
                }
            }
        }
    </script>
    
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <!-- Moment.js -->
    <script src="https://cdn.jsdelivr.net/npm/moment@2.29.4/min/moment.min.js"></script>
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="text-white relative min-h-screen">

<!-- Aurora Background -->
<div class="aurora-bg">
    <div class="aurora-orb aurora-orb-1"></div>
    <div class="aurora-orb aurora-orb-2"></div>
    <div class="aurora-orb aurora-orb-3"></div>
</div>
<div class="noise-overlay"></div>

<!-- Navbar -->
<nav class="glass-nav">
    <div class="w-full max-w-[1400px] mx-auto flex items-center justify-between">
        <a href="/" class="nav-logo">
            <i class="fa-solid fa-cloud-bolt"></i>
            Smart Weather
        </a>

        <% if (typeof user !== 'undefined' && user) { %>
        <div class="flex items-center gap-3">
            <!-- System Status -->
            <div class="system-status hidden md:flex">
                <span class="dot"></span> System Online
            </div>

            <!-- Nav Links -->
            <div class="flex items-center gap-1">
                <a class="nav-link <%= title === 'Dashboard' ? 'active' : '' %>" href="/">
                    <i class="fa-solid fa-grid-2"></i> Dashboard
                </a>
                <a class="nav-link <%= title === 'History' ? 'active' : '' %>" href="/history">
                    <i class="fa-solid fa-clock-rotate-left"></i> History
                </a>
            </div>

            <!-- User -->
            <div class="flex items-center gap-2 ml-2 pl-3 border-l border-white/10">
                <div class="w-7 h-7 rounded-full bg-gradient-to-br from-primary to-secondary flex items-center justify-center text-xs font-bold">
                    <%= user.username.charAt(0).toUpperCase() %>
                </div>
                <span class="text-white/60 text-sm font-medium hidden md:inline"><%= user.username %></span>
                <a href="/logout" class="btn-logout ml-1">
                    <i class="fa-solid fa-arrow-right-from-bracket"></i>
                </a>
            </div>
        </div>
        <% } %>
    </div>
</nav>

<!-- Main -->
<main class="w-full max-w-[1400px] mx-auto px-4 md:px-6 py-8 relative z-10">
    <%- body %>
</main>

<!-- Socket.IO & Firebase -->
<script src="/socket.io/socket.io.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.22.1/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.22.1/firebase-messaging-compat.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
